generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  

}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  emailVerified DateTime?

  chats         Chat[]
    memories UserMemory[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// model Chat {
//   id        String    @id @default(cuid())
